{
  "$schema": "https://json-structure.org/draft/2020-12/schema",
  "name": "Transaction",
  "type": "object",
  "properties": {
    "transactionId": {
      "type": "string"
    },
    "accountId": {
      "type": "string"
    },
    "transactionType": {
      "type": "string"
    },
    "debitOrCredit": {
      "type": "string"
    },
    "amount": {
      "type": "number"
    },
    "currency": {
      "type": "string"
    },
    "bookingDate": {
      "type": "string"
    },
    "valueDate": {
      "type": "string"
    },
    "processingDate": {
      "type": "string"
    },
    "reference": {
      "type": "string"
    },
    "narrative": {
      "type": "string"
    },
    "counterpartyAccountId": {
      "type": "string"
    },
    "counterpartyName": {
      "type": "string"
    },
    "balance": {
      "type": "number"
    },
    "exchangeRate": {
      "type": "number"
    },
    "chargesAmount": {
      "type": "number"
    },
    "reversalIndicator": {
