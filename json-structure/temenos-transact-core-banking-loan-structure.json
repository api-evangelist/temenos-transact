      "type": "string"
    },
    "customerId": {
      "type": "string"
    },
    "productId": {
      "type": "string"
    },
    "productName": {
      "type": "string"
    },
    "principalAmount": {
      "type": "number"
    },
    "outstandingBalance": {
      "type": "number"
    },
    "currency": {
